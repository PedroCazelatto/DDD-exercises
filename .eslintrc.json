{
  "extends": [
    "@rocketseat/eslint-config/node",
    "plugin:vitest-globals/recommended"
  ],
  "rules": {
    "no-useless-constructor": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "quotes": ["error", "double"],
    "prettier/prettier": [
      "error",
      {
        "singleQuote": false,
        "trailingComma": "none",
        "arrowParens": "avoid",
        "semi": false
      }
    ]
  },
  "env": {
    "vitest-globals/env": true
  }
}
